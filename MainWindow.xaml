<Window x:Class="STM32GatewayGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="STM32 Gateway" Height="650" Width="520"
        Background="#1E1E2E" Foreground="#CDD6F4"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="CatSurface0" Color="#313244"/>
        <SolidColorBrush x:Key="CatSurface1" Color="#45475A"/>
        <SolidColorBrush x:Key="CatText" Color="#CDD6F4"/>
        <SolidColorBrush x:Key="CatSubtext0" Color="#A6ADC8"/>
        <SolidColorBrush x:Key="CatGreen" Color="#A6E3A1"/>
        <SolidColorBrush x:Key="CatRed" Color="#F38BA8"/>
        <SolidColorBrush x:Key="CatBlue" Color="#89B4FA"/>
        <SolidColorBrush x:Key="CatYellow" Color="#F9E2AF"/>
        <SolidColorBrush x:Key="CatMauve" Color="#CBA6F7"/>
        <SolidColorBrush x:Key="CatTeal" Color="#94E2D5"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CatSurface0}"/>
            <Setter Property="Foreground" Value="{StaticResource CatText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CatSurface1}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Connection -->
        <Border Grid.Row="0" Background="{StaticResource CatSurface0}" CornerRadius="8" Padding="8" Margin="0,0,0,6">
            <StackPanel>
                <WrapPanel>
                    <TextBlock Text="Gateway" FontWeight="Bold" Foreground="{StaticResource CatMauve}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="CmbPort" Width="90" Height="26"/>
                    <Button x:Name="BtnConnect" Content="Connect" Click="BtnConnect_Click"/>
                    <Button Content="⟳" Click="BtnRefresh_Click" Width="28"/>
                    <TextBlock x:Name="TxtStatus" Text="Disconnected" Foreground="{StaticResource CatRed}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </WrapPanel>
                <WrapPanel Margin="0,3,0,0">
                    <TextBlock Text="CAN 0x" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtCanTarget" Width="30" Height="24" Text="10"
                             Background="{StaticResource CatSurface0}" Foreground="{StaticResource CatText}"/>
                    <TextBlock Text="  MB ID:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <TextBox x:Name="TxtMbSlave" Width="30" Height="24" Text="1"
                             Background="{StaticResource CatSurface0}" Foreground="{StaticResource CatText}"/>
                    <TextBlock Text="  Baud:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                    <ComboBox x:Name="CmbBaud" Width="80" Height="24" SelectedIndex="4">
                        <ComboBoxItem Content="9600"/>
                        <ComboBoxItem Content="19200"/>
                        <ComboBoxItem Content="38400"/>
                        <ComboBoxItem Content="57600"/>
                        <ComboBoxItem Content="115200"/>
                        <ComboBoxItem Content="230400"/>
                        <ComboBoxItem Content="460800"/>
                    </ComboBox>
                    <Button Content="Set" Click="BtnSetBaud_Click" Padding="6,4"/>
                    <TextBlock Text="  via:" VerticalAlignment="Center" Margin="4,0,4,0" Foreground="{StaticResource CatSubtext0}"/>
                    <RadioButton x:Name="RbCan" Content="CAN" IsChecked="True" Foreground="{StaticResource CatTeal}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <RadioButton x:Name="RbModbus" Content="Modbus" Foreground="{StaticResource CatMauve}" VerticalAlignment="Center"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Monitor -->
        <Border Grid.Row="1" Background="{StaticResource CatSurface0}" CornerRadius="8" Padding="8" Margin="0,0,0,6">
            <StackPanel>
                <TextBlock Text="Monitor" FontWeight="Bold" Foreground="{StaticResource CatGreen}" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TxtState" Text="State: —"/>
                        <TextBlock x:Name="TxtTrack" Text="Track: —"/>
                        <TextBlock x:Name="TxtVolume" Text="Volume: —"/>
                        <TextBlock x:Name="TxtRepeat" Text="Repeat: —"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="TxtUptime" Text="Up: —"/>
                        <TextBlock x:Name="TxtTemp" Text="Temp: —"/>
                        <TextBlock x:Name="TxtSD" Text="SD: —"/>
                        <TextBlock x:Name="TxtFormat" Text="Format: —"/>
                        <TextBlock x:Name="TxtRtcDisplay" Text="RTC: —" Foreground="{StaticResource CatMauve}"/>
                    </StackPanel>
                </Grid>
                <TextBlock x:Name="TxtTrackName" Text="♪ —" FontSize="14" Foreground="{StaticResource CatYellow}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                <WrapPanel Margin="0,2,0,0">
                    <TextBlock x:Name="TxtFwVer" Text="FW: —" Foreground="{StaticResource CatSubtext0}" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TxtHeap" Text="Heap: —" Foreground="{StaticResource CatSubtext0}"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Control -->
        <Border Grid.Row="2" Background="{StaticResource CatSurface0}" CornerRadius="8" Padding="8" Margin="0,0,0,6">
            <StackPanel>
                <TextBlock Text="Control" FontWeight="Bold" Foreground="{StaticResource CatBlue}" Margin="0,0,0,4"/>
                <WrapPanel>
                    <Button Content="⏮ Prev" Click="BtnPrev_Click"/>
                    <Button x:Name="BtnPlayPause" Content="▶ Play" Click="BtnPlayPause_Click"/>
                    <Button Content="⏹ Stop" Click="BtnStop_Click"/>
                    <Button Content="⏭ Next" Click="BtnNext_Click"/>
                </WrapPanel>
                <WrapPanel Margin="0,4,0,0">
                    <TextBlock Text="Vol:" VerticalAlignment="Center"/>
                    <Slider x:Name="SliderVol" Width="170" Minimum="0" Maximum="100" Value="80"
                            ValueChanged="SliderVol_Changed" IsSnapToTickEnabled="True" TickFrequency="1"/>
                    <TextBlock x:Name="TxtVol" Text="80%" Width="36" VerticalAlignment="Center"/>
                    <TextBlock Text=" Repeat:" VerticalAlignment="Center" Margin="4,0,4,0"/>
                    <ComboBox x:Name="CmbRepeat" Width="80" Height="24" SelectedIndex="0" SelectionChanged="CmbRepeat_Changed">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="One"/>
                        <ComboBoxItem Content="Off"/>
                        <ComboBoxItem Content="Single"/>
                        <ComboBoxItem Content="Random"/>
                    </ComboBox>
                </WrapPanel>
                <WrapPanel Margin="0,4,0,0">
                    <Button x:Name="BtnMono" Content="Mono: Off" Click="BtnMono_Click"/>
                    <Button x:Name="BtnAutoplay" Content="Auto: On" Click="BtnAutoplay_Click"/>
                    <TextBlock Text=" Goto#" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtGoto" Width="35" Height="24" Text="0"
                             Background="{StaticResource CatSurface0}" Foreground="{StaticResource CatText}"/>
                    <Button Content="Go" Click="BtnGoto_Click"/>
                </WrapPanel>
                <!-- Siggen -->
                <Separator Background="{StaticResource CatSurface1}" Margin="0,6,0,4"/>
                <WrapPanel>
                    <TextBlock Text="Siggen" FontWeight="Bold" Foreground="{StaticResource CatYellow}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CmbSigType" Width="80" Height="24" SelectedIndex="0">
                        <ComboBoxItem Content="Sine"/>
                        <ComboBoxItem Content="Square"/>
                        <ComboBoxItem Content="Triangle"/>
                        <ComboBoxItem Content="Sawtooth"/>
                        <ComboBoxItem Content="White"/>
                        <ComboBoxItem Content="Pink"/>
                    </ComboBox>
                    <TextBox x:Name="TxtSigFreq" Width="50" Height="24" Text="1000" Margin="4,0,0,0"
                             Background="{StaticResource CatSurface0}" Foreground="{StaticResource CatText}"/>
                    <TextBlock Text="Hz" VerticalAlignment="Center" Margin="2,0,4,0"/>
                    <Button Content="▶" Click="BtnSigStart_Click"/>
                    <Button Content="⏹" Click="BtnSigStop_Click"/>
                </WrapPanel>
                <!-- RTC + Raw -->
                <Separator Background="{StaticResource CatSurface1}" Margin="0,6,0,4"/>
                <WrapPanel>
                    <TextBlock x:Name="TxtRtcTime" Text="RTC: —" VerticalAlignment="Center" Foreground="{StaticResource CatMauve}" Margin="0,0,6,0"/>
                    <Button Content="Sync RTC" Click="BtnRtcSync_Click"/>
                    <TextBlock Text="  Reg 0x" VerticalAlignment="Center" Foreground="{StaticResource CatSubtext0}" Margin="8,0,0,0"/>
                    <TextBox x:Name="TxtRegAddr" Width="40" Height="24" Text="0000"
                             Background="{StaticResource CatSurface0}" Foreground="{StaticResource CatText}"/>
                    <TextBlock Text="×" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtRegCount" Width="24" Height="24" Text="1"
                             Background="{StaticResource CatSurface0}" Foreground="{StaticResource CatText}"/>
                    <Button Content="R" Click="BtnRegRead_Click" Width="24"/>
                    <TextBlock Text="=" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtRegVal" Width="45" Height="24" Text="0000"
                             Background="{StaticResource CatSurface0}" Foreground="{StaticResource CatText}"/>
                    <Button Content="W" Click="BtnRegWrite_Click" Width="24"/>
                </WrapPanel>
                <TextBlock x:Name="TxtRegResult" Text="" Foreground="{StaticResource CatSubtext0}" Margin="0,2,0,0" TextWrapping="Wrap" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- Log -->
        <Border Grid.Row="3" Background="{StaticResource CatSurface0}" CornerRadius="8" Padding="8">
            <DockPanel>
                <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                    <TextBlock Text="Log" FontWeight="Bold" Foreground="{StaticResource CatSubtext0}"/>
                    <Button Content="Clear" Click="BtnClear_Click" Margin="8,0,0,0" Padding="6,2"/>
                </WrapPanel>
                <TextBox x:Name="TxtLog" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                         Background="#181825" Foreground="{StaticResource CatSubtext0}" FontFamily="Cascadia Mono,Consolas"
                         FontSize="11" TextWrapping="Wrap" BorderThickness="0"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
